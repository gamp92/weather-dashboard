# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Force LF for these types
*.ts    text eol=lf
*.html  text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.js    text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
